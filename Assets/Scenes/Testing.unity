      m_Calls: []
  m_text: "\u041D\u0430\u0436\u0438\u043C\u0430\u044F \u043D\u0430 [\u041B\u041A\u041C]
    \u0432\u044B \u0431\u0440\u043E\u0441\u0430\u0435\u0442\u0435 \u043A\u0440\u044E\u043A.\n\u041D\u0430\u0436\u0438\u043C\u0430\u044F
    [\u041F\u041A\u041C] \u0432\u044B \u0443\u0431\u0438\u0440\u0430\u0435\u0442\u0435
    \u043A\u0440\u044E\u043A.\n\n\u0421 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u043A\u043E\u043B\u0435\u0441\u0438\u043A\u0430 \u043C\u044B\u0448\u0438 \u043C\u043E\u0436\u043D\u043E
    \u043C\u0435\u043D\u044F\u0442\u044C \u0441\u0438\u043B\u0443 \u043F\u0440\u0438\u0442\u044F\u0433\u0438\u0432\u0430\u043D\u0438\u044F
    \u043A\u0440\u044E\u043A\u0430.\n\n\u041A\u0440\u044E\u043A \u043C\u043E\u0436\u0435\u0442
    \u0446\u0435\u043F\u043B\u044F\u0442\u044C\u0441\u044F \u043D\u0435 \u0437\u0430
    \u0432\u0441\u0435 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438.\n\n\u0418\u0433\u0440\u043E\u043A\u043E\u043C
    \u043D\u0435\u043B\u044C\u0437\u044F \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u0442\u044C
    \u0432 \u0432\u043E\u0437\u0434\u0443\u0445\u0435."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 2706fa10b1ab7a446b233fce68377599, type: 2}
