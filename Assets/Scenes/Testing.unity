  m_text: "\u0413\u043B\u0443\u0431\u0438\u043D\u043D\u0430\u044F \u043F\u043E\u0440\u043E\u0434\u0430,
    \u0441\u0432\u0435\u0442\u044F\u0449\u0430\u044F\u0441\u044F \u0434\u0430\u0436\u0435
    \u0432 \u043F\u043E\u043B\u043D\u043E\u0439 \u0442\u0435\u043C\u043D\u043E\u0442\u0435.\n\u0418\u0437\u043B\u0443\u0447\u0430\u0435\u0442
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0440\u0430\u0434\u0438\u0430\u0446\u0438\u0438.\n\n\u0415\u0441\u043B\u0438
    \u0432\u0430\u0448\u0430 \u0436\u0438\u0437\u043D\u044C \u043D\u0435 \u043E\u0441\u043E\u0431\u043E
    \u0434\u043E\u0440\u043E\u0433\u0430, \u0445\u0432\u0430\u0442\u0430\u0439\u0442\u0435
    \u0435\u0433\u043E \u0441\u043C\u0435\u043B\u043E."
