  m_text: "\u042F\u0440\u043A\u0438\u0439 \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B
    \u0438\u0437\u043B\u0443\u0447\u0430\u044E\u0449\u0438\u0439 \u0440\u0430\u0434\u0438\u0430\u0446\u0438\u044E.
    \u041F\u043E\u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0433\u043B\u0443\u0431\u043E\u043A\u043E
