    \u0441 \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\u043E\u043C, \u043E\u043D
    \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442 \u0443\u0440\u043E\u043D.\n\n\u0415\u0441\u043B\u0438
    \u0436\u0435 \u0438\u0433\u0440\u043E\u043A \u043D\u0430\u0434\u0435\u043B \u0445\u0438\u043C
    \u043A\u043E\u0441\u0442\u044E\u043C, \u043E\u043D \u043D\u0435 \u0431\u0443\u0434\u0435\u0442
